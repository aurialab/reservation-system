generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String
  surname      String
  phone        String
  passwordHash String
  isVerified   Boolean       @default(false)
  isBO         Boolean       @default(false)

  reservations            Reservation[]
  notifications           Notification[]
  pushTokens              PushToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model Activity {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  sessions Session[]
}

model Instructor {
  id       Int   @id @default(autoincrement())
  name     String
  surname  String
  email    String @unique
  phone    String
  schedule Json?
  holidays Json   @default("[]")

  sessions Session[]
  services Service[]
}

model Service {
  id   Int    @id @default(autoincrement())
  name String

  instructors Instructor[]
}

model Session {
  id           Int       @id @default(autoincrement())
  activityId   Int
  instructorId Int
  locationId   Int
  startDate    DateTime  @db.Date
  endDate      DateTime  @db.Date
  weekDays     WeekDay[]
  startTime    String
  endTime      String

  activity     Activity      @relation(fields: [activityId], references: [id])
  instructor   Instructor    @relation(fields: [instructorId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  reservations Reservation[]

  @@index([activityId])
  @@index([instructorId])
  @@index([locationId])
  @@index([startDate])
  @@index([endDate])
}

model Reservation {
  id             Int               @id @default(autoincrement())
  userId         Int
  sessionId      Int
  occurrenceDate DateTime?         @db.Date
  observations   String?
  state          ReservationStatus @default(PENDING)

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@index([occurrenceDate])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model PushToken {
  id     Int    @id @default(autoincrement())
  userId Int
  token  String

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Layer {
  id        Int    @id @default(autoincrement())
  latitude  Float
  longitude Float
  zone      String
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Business {
  id        Int            @id @default(autoincrement())
  name      String
  createdAt DateTime       @default(now())
  status    BusinessStatus @default(ACTIVE)

  locations Location[]
}

model Location {
  id         Int      @id @default(autoincrement())
  name       String
  city       String
  postalCode String
  address    String
  latitude   Float?
  longitude  Float?
  phone      String?
  email      String?
  isActive   Boolean  @default(true)
  businessId Int

  business Business  @relation(fields: [businessId], references: [id])
  sessions Session[]

  @@index([businessId])
}
